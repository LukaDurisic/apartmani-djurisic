# EmailJS configuration for the enquiry form.
# Copy this file to `.env.local` and fill in your real values, then rebuild.
# (See SETUP-EMAILJS.md for step-by-step instructions.)
#
# These are NOT secrets — the public key is meant to live in the browser —
# but .env.local is git-ignored so your account details stay off GitHub.

NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_owner_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Optional — a second template that sends the guest a confirmation (auto-reply).
# Leave blank to disable auto-reply.
NEXT_PUBLIC_EMAILJS_AUTOREPLY_TEMPLATE_ID=your_autoreply_template_id
